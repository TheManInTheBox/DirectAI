{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for DirectAI metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "DirectAI Inference Platform — per-model latency, throughput, error rate, TTFT, GPU utilization, and node pool health.",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "API Server — Request Overview",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "title": "Request Rate (per model)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(directai_requests_total[5m])) by (model)",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "title": "Error Rate (per model)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(directai_requests_total{status=\"error\"}[5m])) by (model) / sum(rate(directai_requests_total[5m])) by (model)",
          "legendFormat": "{{ model }}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "thresholds": {
        "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.01 },
          { "color": "red", "value": 0.05 }
        ]
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "title": "Inflight Requests (per model)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "directai_backend_inflight_requests",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "title": "Latency Percentiles — P50 / P95 / P99",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(directai_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{ model }} P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(directai_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{ model }} P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(directai_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{ model }} P99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 10,
      "title": "LLM Engine",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 11,
      "title": "Time to First Token (TTFT)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(directai_llm_time_to_first_token_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(directai_llm_time_to_first_token_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(directai_llm_time_to_first_token_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 12,
      "title": "Token Throughput (tokens/sec)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(directai_llm_tokens_generated_total[5m])",
          "legendFormat": "Generated tokens/s"
        },
        {
          "expr": "rate(directai_llm_prompt_tokens_total[5m])",
          "legendFormat": "Prompt tokens/s"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 13,
      "title": "LLM Inflight Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "directai_llm_inflight_requests",
          "legendFormat": "Inflight"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 14,
      "title": "LLM Request Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(directai_llm_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(directai_llm_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 20,
      "title": "Embedding Engine",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 },
      "id": 21,
      "title": "Embedding Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(directai_embed_requests_total{status=\"ok\"}[5m])",
          "legendFormat": "OK"
        },
        {
          "expr": "rate(directai_embed_requests_total{status=\"error\"}[5m])",
          "legendFormat": "Error"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 35 },
      "id": 22,
      "title": "Embedding Batch Size",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(directai_embed_batch_size_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(directai_embed_batch_size_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 35 },
      "id": 23,
      "title": "Embedding Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(directai_embed_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(directai_embed_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 30,
      "title": "GPU Health (DCGM)",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "id": 31,
      "title": "GPU Utilization",
      "type": "timeseries",
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{ gpu }} @ {{ instance }}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "id": 32,
      "title": "GPU Framebuffer Memory",
      "type": "timeseries",
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "Used — GPU {{ gpu }}"
        },
        {
          "expr": "DCGM_FI_DEV_FB_FREE",
          "legendFormat": "Free — GPU {{ gpu }}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "celsius" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 52 },
      "id": 33,
      "title": "GPU Temperature",
      "type": "timeseries",
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "GPU {{ gpu }} @ {{ instance }}"
        }
      ],
      "thresholds": {
        "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 75 },
          { "color": "red", "value": 85 }
        ]
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "watt" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 52 },
      "id": 34,
      "title": "GPU Power Draw",
      "type": "timeseries",
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "GPU {{ gpu }} @ {{ instance }}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 52 },
      "id": 35,
      "title": "Tensor Core Activity",
      "type": "timeseries",
      "targets": [
        {
          "expr": "DCGM_FI_PROF_PIPE_TENSOR_ACTIVE",
          "legendFormat": "GPU {{ gpu }} @ {{ instance }}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 60 },
      "id": 36,
      "title": "NVLink Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(DCGM_FI_PROF_NVLINK_TX_BYTES[5m])",
          "legendFormat": "TX — GPU {{ gpu }}"
        },
        {
          "expr": "rate(DCGM_FI_PROF_NVLINK_RX_BYTES[5m])",
          "legendFormat": "RX — GPU {{ gpu }}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 60 },
      "id": 37,
      "title": "PCIe Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(DCGM_FI_PROF_PCIE_TX_BYTES[5m])",
          "legendFormat": "TX — GPU {{ gpu }}"
        },
        {
          "expr": "rate(DCGM_FI_PROF_PCIE_RX_BYTES[5m])",
          "legendFormat": "RX — GPU {{ gpu }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 68 },
      "id": 40,
      "title": "Whisper (Transcription)",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 69 },
      "id": 41,
      "title": "Whisper Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(directai_whisper_requests_total[5m])",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 69 },
      "id": 42,
      "title": "Whisper Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(directai_whisper_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(directai_whisper_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 69 },
      "id": 43,
      "title": "Whisper Preprocessing Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(directai_whisper_preprocessing_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 preprocess"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["directai", "inference", "gpu", "llm", "embeddings"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "DirectAI Inference Platform",
  "uid": "directai-overview",
  "version": 1
}
