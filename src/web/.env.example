# =============================================================================
# DirectAI Web App — Environment Variables
#
# Copy to .env.local for local development.
# In production, these are set via Key Vault → workload identity → env vars.
# =============================================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://directaiadmin:changeme@localhost:5432/directai

# --- NextAuth (Session Management) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Entra External ID (OIDC Provider) ---
# Issuer: https://{tenant-subdomain}.ciamlogin.com/{tenant-id}/v2.0
AUTH_ENTRA_EXTERNAL_ISSUER=
AUTH_ENTRA_EXTERNAL_CLIENT_ID=
AUTH_ENTRA_EXTERNAL_CLIENT_SECRET=

# --- Stripe (Billing) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_METER_ID_TOKENS=directai_token_usage

# Stripe Price IDs (created in Stripe Dashboard)
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# --- Azure Table Storage (Waitlist — existing) ---
AZURE_STORAGE_CONNECTION_STRING=
