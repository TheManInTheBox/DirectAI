# ──────────────────────────────────────────────────────────
# DirectAI — Environment Variables
# Copy to .env and fill in values for local development.
# ──────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────
DIRECTAI_HOST=0.0.0.0
DIRECTAI_PORT=8000
DIRECTAI_LOG_LEVEL=info

# Model configuration directory (YAML files)
DIRECTAI_MODEL_CONFIG_DIR=./deploy/models/local

# Auth — comma-separated API keys. Empty = auth disabled (dev only).
DIRECTAI_API_KEYS=

# Backend proxy timeouts (seconds)
DIRECTAI_BACKEND_TIMEOUT=300
DIRECTAI_BACKEND_CONNECT_TIMEOUT=5

# Rate limiting
DIRECTAI_RATE_LIMIT_RPM=60
DIRECTAI_RATE_LIMIT_TPM=100000
DIRECTAI_RATE_LIMIT_BURST=120

# ── Database (PostgreSQL) ─────────────────────────────────
# Required for API key auth, usage metering, and billing.
# Leave empty for local dev (auth falls back to DIRECTAI_API_KEYS).
DIRECTAI_DATABASE_URL=
# DATABASE_URL=postgresql://directaiadmin:changeme@localhost:5432/directai?sslmode=require

# SQLite path for model lifecycle state (native API).
# Leave empty for in-memory (dev only).
DIRECTAI_DATABASE_PATH=

# API key in-memory cache TTL (seconds)
DIRECTAI_KEY_CACHE_TTL=60

# ── Stripe Billing ────────────────────────────────────────
# Required for usage reporting. Leave empty to disable billing.
DIRECTAI_STRIPE_SECRET_KEY=
DIRECTAI_STRIPE_METER_ID_TOKENS=
DIRECTAI_USAGE_REPORT_INTERVAL=60

# ── Observability (OpenTelemetry) ─────────────────────────
DIRECTAI_OTEL_ENABLED=true
DIRECTAI_OTEL_SAMPLE_RATE=1.0

# Azure Application Insights connection string
DIRECTAI_APPINSIGHTS_CONNECTION_STRING=

# OTLP gRPC endpoint (e.g., http://localhost:4317)
DIRECTAI_OTLP_ENDPOINT=

# ── Web App (Next.js) ────────────────────────────────────
# NextAuth
AUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
AUTH_ENTRA_EXTERNAL_ISSUER=
AUTH_ENTRA_EXTERNAL_CLIENT_ID=
AUTH_ENTRA_EXTERNAL_CLIENT_SECRET=

# Stripe (client-side)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_METER_ID_TOKENS=

# Database (shared with API server or separate)
# DATABASE_URL=postgresql://directaiadmin:changeme@localhost:5432/directai?sslmode=require

# ── Embeddings Engine ────────────────────────────────────
EMBED_MODEL_PATH=./models/bge-large-en-v1.5/model.onnx
EMBED_TOKENIZER_PATH=./models/bge-large-en-v1.5
EMBED_MAX_SEQ_LENGTH=512
EMBED_MAX_BATCH_SIZE=256
EMBED_EXECUTION_PROVIDER=CUDAExecutionProvider

# ── TRT-LLM Engine ──────────────────────────────────────
TRTLLM_ENGINE_DIR=/models/engine
TRTLLM_TOKENIZER_DIR=/models/tokenizer
TRTLLM_TP_SIZE=1
TRTLLM_PP_SIZE=1
TRTLLM_KV_CACHE_FREE_GPU_MEM_FRACTION=0.85
TRTLLM_MAX_BATCH_SIZE=64
